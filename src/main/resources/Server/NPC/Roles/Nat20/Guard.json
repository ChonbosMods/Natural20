{
  "Type": "Generic",
  "StartState": "Idle",
  "NameTranslationKey": "nat20.npc.guard",
  "DisplayNames": [
    "Guard"
  ],
  "DefaultNPCAttitude": "HOSTILE",
  "DefaultPlayerAttitude": "Neutral",
  "AttitudeGroup": "Nat20_Settlement",
  "Appearance": "NPC_Elf",
  "MaxHealth": 30,
  "KnockbackScale": 0.5,
  "HotbarItems": ["Weapon_Sword_Mithril"],
  "HotbarSize": 3,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 8,
      "Gravity": 10,
      "RunThreshold": 0.5,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "Instructions": [
    {
      "Continue": true,
      "Instructions": [{
        "Continue": true,
        "Sensor": { "Type": "Any", "Once": true },
        "Actions": [{
          "Type": "Inventory",
          "Operation": "EquipHotbar",
          "Slot": 0,
          "UseTarget": false
        }]
      }]
    },
    {
      "$Comment": "Damage detection: any state, store attacker in LockedTarget, enter Combat",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": {
            "Type": "Damage",
            "Combat": true,
            "TargetSlot": "LockedTarget"
          },
          "Actions": [
            {
              "Type": "State",
              "State": "Combat"
            }
          ]
        }
      ]
    },
    {
      "Instructions": [
        {
          "$Comment": "Idle: stand guard, watch nearby players",
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "If plugin marked a target in LockedTarget, enter Combat",
              "Sensor": {
                "Type": "Target",
                "TargetSlot": "LockedTarget",
                "Range": 20
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Combat"
                }
              ]
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": 16
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        },
        {
          "$Comment": "Combat: chase and engage hostile target",
          "Sensor": {
            "Type": "State",
            "State": "Combat"
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "Target",
                "TargetSlot": "LockedTarget",
                "Range": 24
              },
              "HeadMotion": {
                "Type": "Watch"
              },
              "BodyMotion": {
                "Type": "Seek",
                "StopDistance": 2.5,
                "SlowDownDistance": 4,
                "RelativeSpeed": 1.0
              }
            },
            {
              "$Comment": "No target in LockedTarget: return to post",
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "Target",
                  "TargetSlot": "LockedTarget",
                  "Range": 24
                }
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "ReturnToPost"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "ReturnToPost: walk back to leash point",
          "Sensor": {
            "Type": "State",
            "State": "ReturnToPost"
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "Leash",
                "Range": 100
              },
              "BodyMotion": {
                "Type": "Seek",
                "StopDistance": 1,
                "SlowDownDistance": 5,
                "RelativeSpeed": 0.4,
                "UsePathfinder": true
              }
            },
            {
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "Leash",
                  "Range": 3
                }
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionVars": {
    "nat20_role": "guard"
  }
}
