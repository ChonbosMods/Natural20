  "BusyStates": ["Fleeing"],
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 7,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "DecisionMaker": {
