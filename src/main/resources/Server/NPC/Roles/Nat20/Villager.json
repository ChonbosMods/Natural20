          { "Type": "HasTarget", "Score": 0.9 },
          { "Type": "KnownTargetCount", "Attitude": "Hostile", "Min": 1, "Score": 0.85 }
        ]
      }
    ]
  },
  "Instructions": [
    {
      "Instructions": [
        {
          "$Comment": "Idle: wander slowly in a circle, pause, repeat",
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": 8
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Sequence",
                "Looped": true,
                "Motions": [
                  {
                    "Type": "Timer",
                    "Time": [3, 6],
                    "Motion": {
                      "Type": "Nothing"
                    }
                  },
                  {
                    "Type": "Timer",
                    "Time": [2, 4],
                    "Motion": {
                      "Type": "WanderInCircle",
                      "Radius": 6,
                      "MaxHeadingChange": 60,
                      "RelativeSpeed": 0.15
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "$Comment": "Fleeing: run away from hostile threat",
          "Sensor": {
            "Type": "State",
            "State": "Fleeing"
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "HasTarget"
              },
              "BodyMotion": {
                "Type": "Flee",
                "RelativeSpeed": 1.0
              }
            },
            {
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "HasTarget"
                }
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [5, 5],
                  "Action": {
                    "Type": "State",
                    "State": "Idle"
                  }
                }
              ],
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        }
      ]
    }
  ],
  "InteractionVars": {
    "nat20_role": "villager"
  }
