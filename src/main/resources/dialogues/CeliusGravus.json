  "nodes": {
    "celius_greeting": {
      "type": "DIALOGUE",
      "speakerText": "Stay sharp out there. The road past the gate has a way of sorting the prepared from the hopeful.",
      "responses": []
    },

    "node_tutorial_phase1_entry": {
      "type": "DIALOGUE",
      "speakerText": "Good, Jiub sent word. That man has an eye for who's useful, and he says you are.",
      "responses": [
        {
          "id": "phase1_continue",
          "displayText": "Continue",
          "targetNodeId": "node_tutorial_phase1_assign",
          "mode": "DECISIVE",
          "responseType": "CONTINUE"
        }
      ],
      "onEnter": [
        { "type": "TUTORIAL_TURN_IN_PHASE_1" }
      ]
    },
    "node_tutorial_phase1_assign": {
      "type": "DIALOGUE",
      "speakerText": "Head to {target_npc_settlement} and find {target_npc}. I've marked their location on your map. They have valuable information concerning a great threat to our village.",
      "responses": [],
      "exhaustsTopic": true
    },

    "node_tutorial_phase2_entry": {
      "type": "DIALOGUE",
      "speakerText": "Back already, good. Now we know who we're facing, and {target_npc} has given us the ground to meet them on.",
      "responses": [
        {
          "id": "phase2_continue",
          "displayText": "Continue",
          "targetNodeId": "node_tutorial_phase2_assign",
          "mode": "DECISIVE",
          "responseType": "CONTINUE"
        }
      ],
      "onEnter": [
        { "type": "TUTORIAL_TURN_IN_PHASE_2" }
      ]
    },
    "node_tutorial_phase2_assign": {
      "type": "DIALOGUE",
      "speakerText": "This threat ends with {boss_name}'s death. Go to their lair and finish what they started, I've marked the general area on your map, you'll have to search underground for the exact spot.",
      "responses": [],
      "exhaustsTopic": true
    },

    "node_tutorial_phase3_entry": {
      "type": "DIALOGUE",
      "speakerText": "You found {boss_name} and put them in the ground. We heard the work from here.",
      "responses": [
        {
          "id": "phase3_continue",
          "displayText": "Continue",
          "targetNodeId": "node_tutorial_phase3_close",
          "mode": "DECISIVE",
          "responseType": "CONTINUE"
        }
      ],
      "onEnter": [
