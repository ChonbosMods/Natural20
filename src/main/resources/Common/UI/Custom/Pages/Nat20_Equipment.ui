$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 520, Height: 480);

  #Content {
    LayoutMode: Top;
    Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

    // Title
    Group {
      LayoutMode: Left;
      Anchor: (Height: 32);
      Padding: (Bottom: 8);

      Label { FlexWeight: 1; }
      Label #EqTitle {
        Text: "Equipment";
        Style: (TextColor: #ffd700(1), FontSize: 22, RenderBold: true);
      }
      Label { FlexWeight: 1; }
    }

    // Armor section header
    Label #EqArmorHeader {
      Text: "Armor";
      Style: (TextColor: #aaaaaa(1), FontSize: 13, RenderBold: true);
      Anchor: (Height: 20);
    }

    // Armor slots (4 slots in a row)
    Group {
      LayoutMode: LeftCenterWrap;
      Anchor: (Height: 64);
      Padding: (Top: 4, Bottom: 8);

      Group #EqArmorSlot0 {
        Anchor: (Width: 56, Height: 56);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqArmorIcon0 {
          Anchor: (Left: 4, Top: 4, Right: 4, Bottom: 4);
        }
      }

      Group #EqArmorSlot1 {
        Anchor: (Width: 56, Height: 56, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqArmorIcon1 {
          Anchor: (Left: 4, Top: 4, Right: 4, Bottom: 4);
        }
      }

      Group #EqArmorSlot2 {
        Anchor: (Width: 56, Height: 56, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqArmorIcon2 {
          Anchor: (Left: 4, Top: 4, Right: 4, Bottom: 4);
        }
      }

      Group #EqArmorSlot3 {
        Anchor: (Width: 56, Height: 56, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqArmorIcon3 {
          Anchor: (Left: 4, Top: 4, Right: 4, Bottom: 4);
        }
      }
    }

    // Hotbar section header
    Label #EqHotbarHeader {
      Text: "Hotbar";
      Style: (TextColor: #aaaaaa(1), FontSize: 13, RenderBold: true);
      Anchor: (Height: 20);
    }

    // Hotbar slots (9 slots, wrapping into rows)
    Group {
      LayoutMode: LeftCenterWrap;
      Padding: (Top: 4, Bottom: 4);
      FlexWeight: 1;

      Group #EqHotbarSlot0 {
        Anchor: (Width: 50, Height: 50);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon0 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot1 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon1 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot2 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon2 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot3 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon3 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot4 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon4 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot5 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon5 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot6 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon6 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot7 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon7 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }

      Group #EqHotbarSlot8 {
        Anchor: (Width: 50, Height: 50, Left: 4);
        TooltipTextSpans: "";
        TextTooltipStyle: $C.@DefaultTextTooltipStyle;
        Background: (Color: #2a2a3e(0.7));
        Padding: (Left: 4, Right: 4, Top: 4, Bottom: 4);
        ItemIcon #EqHotbarIcon8 {
          Anchor: (Left: 3, Top: 3, Right: 3, Bottom: 3);
        }
      }
    }

    // Hint text at bottom
    Label #EqHint {
      Text: "Hover over items to see Nat20 stats.";
      Style: (TextColor: #666666(1), FontSize: 11);
      Anchor: (Height: 18);
    }
  }
}

$C.@BackButton {}
