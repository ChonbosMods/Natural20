$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 420, Height: 520);

  #Content {
    LayoutMode: Top;
    Padding: (Left: 24, Right: 24, Top: 18, Bottom: 16);

    // Title bar: centered
    Group {
      LayoutMode: Left;
      Anchor: (Height: 30);
      Padding: (Bottom: 2);

      Label { FlexWeight: 1; }
      Label #SCTitle {
        Text: "Skill Check";
        Style: (TextColor: #ffd700(1), FontSize: 20, RenderBold: true);
      }
      Label { FlexWeight: 1; }
    }

    // DC line: "Difficulty Class 14" (under title, above dice)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 22);
      Padding: (Top: 2);

      Label { FlexWeight: 1; }
      Label #DCInfo {
        Text: "";
        Style: (TextColor: #ffffff(1), FontSize: 14, RenderBold: true);
      }
      Label { FlexWeight: 1; }
    }

    // Dice image container: stacked frames, only one visible at a time.
    // Die A is always visible. Die B + gap + mode label shown only for advantage/disadvantage.
    Group {
      LayoutMode: Left;
      Anchor: (Height: 132);
      Padding: (Top: 6, Bottom: 4);

      Label { FlexWeight: 1; }
      Group #DieA {
        Anchor: (Width: 110, Height: 110);

        // Tumble frames (10)
        Group #AT01 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_01.png"); Visible: false; }
        Group #AT02 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_02.png"); Visible: false; }
        Group #AT03 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_03.png"); Visible: false; }
        Group #AT04 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_04.png"); Visible: false; }
        Group #AT05 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_05.png"); Visible: false; }
        Group #AT06 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_06.png"); Visible: false; }
        Group #AT07 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_07.png"); Visible: false; }
        Group #AT08 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_08.png"); Visible: false; }
        Group #AT09 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_09.png"); Visible: false; }
        Group #AT10 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_10.png"); Visible: false; }

        // Result frames (20)
        Group #AR01 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_01.png"); Visible: false; }
        Group #AR02 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_02.png"); Visible: false; }
        Group #AR03 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_03.png"); Visible: false; }
        Group #AR04 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_04.png"); Visible: false; }
        Group #AR05 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_05.png"); Visible: false; }
        Group #AR06 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_06.png"); Visible: false; }
        Group #AR07 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_07.png"); Visible: false; }
        Group #AR08 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_08.png"); Visible: false; }
        Group #AR09 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_09.png"); Visible: false; }
        Group #AR10 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_10.png"); Visible: false; }
        Group #AR11 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_11.png"); Visible: false; }
        Group #AR12 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_12.png"); Visible: false; }
        Group #AR13 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_13.png"); Visible: false; }
        Group #AR14 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_14.png"); Visible: false; }
        Group #AR15 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_15.png"); Visible: false; }
        Group #AR16 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_16.png"); Visible: false; }
        Group #AR17 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_17.png"); Visible: false; }
        Group #AR18 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_18.png"); Visible: false; }
        Group #AR19 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_19.png"); Visible: false; }
        Group #AR20 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_20.png"); Visible: false; }
      }
      Group #DiceGap { Anchor: (Width: 20, Height: 110); Visible: false; }
      Group #DieB {
        Anchor: (Width: 110, Height: 110);
        Visible: false;

        // Tumble frames (10)
        Group #BT01 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_01.png"); Visible: false; }
        Group #BT02 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_02.png"); Visible: false; }
        Group #BT03 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_03.png"); Visible: false; }
        Group #BT04 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_04.png"); Visible: false; }
        Group #BT05 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_05.png"); Visible: false; }
        Group #BT06 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_06.png"); Visible: false; }
        Group #BT07 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_07.png"); Visible: false; }
        Group #BT08 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_08.png"); Visible: false; }
        Group #BT09 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_09.png"); Visible: false; }
        Group #BT10 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_tumble_10.png"); Visible: false; }

        // Result frames (20)
        Group #BR01 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_01.png"); Visible: false; }
        Group #BR02 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_02.png"); Visible: false; }
        Group #BR03 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_03.png"); Visible: false; }
        Group #BR04 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_04.png"); Visible: false; }
        Group #BR05 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_05.png"); Visible: false; }
        Group #BR06 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_06.png"); Visible: false; }
        Group #BR07 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_07.png"); Visible: false; }
        Group #BR08 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_08.png"); Visible: false; }
        Group #BR09 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_09.png"); Visible: false; }
        Group #BR10 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_10.png"); Visible: false; }
        Group #BR11 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_11.png"); Visible: false; }
        Group #BR12 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_12.png"); Visible: false; }
        Group #BR13 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_13.png"); Visible: false; }
        Group #BR14 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_14.png"); Visible: false; }
        Group #BR15 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_15.png"); Visible: false; }
        Group #BR16 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_16.png"); Visible: false; }
        Group #BR17 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_17.png"); Visible: false; }
        Group #BR18 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_18.png"); Visible: false; }
        Group #BR19 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_19.png"); Visible: false; }
        Group #BR20 { Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0); Background: (TexturePath: "d20_result_20.png"); Visible: false; }
      }
      Label { FlexWeight: 1; }
    }

    // Mode label: "Advantage" or "Disadvantage" (visible only for adv/dis rolls)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 20);
      Padding: (Top: 2);

      Label { FlexWeight: 1; }
      Label #ModeLabel {
        Text: "";
        Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
        Visible: false;
      }
      Label { FlexWeight: 1; }
    }

    // Dice result text (shown after roll settles): large number, colored
    Group {
      LayoutMode: Left;
      Anchor: (Height: 28);

      Label { FlexWeight: 1; }
      Label #DiceResultText {
        Text: "";
        Style: (TextColor: #ffcc00(1), FontSize: 22, RenderBold: true);
        Visible: false;
      }
      Label { FlexWeight: 1; }
    }

    // Skill name: "PERSUASION" (bold, white, prominent)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 24);
      Padding: (Top: 2);

      Label { FlexWeight: 1; }
      Label #SkillName {
        Text: "";
        Style: (TextColor: #ffffff(1), FontSize: 16, RenderBold: true);
      }
      Label { FlexWeight: 1; }
    }

    // Stat line: "[CHA] Charisma" (smaller, muted)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 18);

      Label { FlexWeight: 1; }
      Label #StatInfo {
        Text: "";
        Style: (TextColor: #aaaaaa(1), FontSize: 12);
      }
      Label { FlexWeight: 1; }
    }

    // Modifier line: "Charisma +0     Proficiency +0"
    Group {
      LayoutMode: Left;
      Anchor: (Height: 18);
      Padding: (Top: 2);

      Label { FlexWeight: 1; }
      Label #ModInfo {
        Text: "";
        Style: (TextColor: #aaaaaa(1), FontSize: 12);
      }
      Label { FlexWeight: 1; }
    }

    // Roll button (shown pre-roll): directly after modifiers
    Group {
      LayoutMode: Left;
      Anchor: (Height: 44);
      Padding: (Top: 10);

      Label { FlexWeight: 2; }
      $C.@SecondaryTextButton #RollButton {
        Text: "Roll!";
        FlexWeight: 3;
      }
      Label { FlexWeight: 2; }
    }

    // Comparison line: "11 vs 14" (shown post-roll, colored total vs plain number)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 22);
      Padding: (Top: 6);

      Label { FlexWeight: 1; }
      Label #ComparisonLine {
        Text: "";
        Style: (TextColor: #ffffff(1), FontSize: 15, RenderBold: true);
        Visible: false;
      }
      Label { FlexWeight: 1; }
    }

    // Verdict line: "SUCCESS" / "FAILURE" (shown post-roll)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 30);
      Padding: (Top: 4);

      Label { FlexWeight: 1; }
      Label #Verdict {
        Text: "";
        Style: (TextColor: #00cc00(1), FontSize: 22, RenderBold: true);
        Visible: false;
      }
      Label { FlexWeight: 1; }
    }

    // Verdict sub-line: "CRITICAL SUCCESS" (shown for nat 20/1 only)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 20);

      Label { FlexWeight: 1; }
      Label #VerdictSub {
        Text: "";
        Style: (TextColor: #00cc00(1), FontSize: 14, RenderBold: true);
        Visible: false;
      }
      Label { FlexWeight: 1; }
    }

    // Spacer (pushes Continue to bottom)
    Label { FlexWeight: 1; }

    // Continue button (shown post-roll, pinned to bottom)
    Group {
      LayoutMode: Left;
      Anchor: (Height: 44);
      Padding: (Top: 4);

      Label { FlexWeight: 2; }
      $C.@SecondaryTextButton #ContinueButton {
        Text: "Continue";
        FlexWeight: 3;
        Visible: false;
      }
      Label { FlexWeight: 2; }
    }
  }
}
