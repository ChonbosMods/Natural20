$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 600, Height: 620);

  #Content {
    LayoutMode: Top;
    Padding: (Left: 20, Right: 20, Top: 16, Bottom: 16);

    // Title bar
    Group {
      LayoutMode: Left;
      Anchor: (Height: 36);
      Padding: (Bottom: 10);

      Label { FlexWeight: 1; }
      Label #BgPickerTitle {
        Text: "Choose your Background";
        Style: (
          TextColor: #ffd700(1),
          FontSize: 22,
          RenderBold: true
        );
      }
      Label { FlexWeight: 1; }
    }

    // -------------------------------------------------------------------
    // Screen 1: grid of 15 backgrounds (visible by default)
    // -------------------------------------------------------------------
    Group #BgGridGroup {
      LayoutMode: Top;
      FlexWeight: 1;
      Padding: (Top: 4);

      // Row 1
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 4);

        $C.@SmallSecondaryTextButton #BgBtn1 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        $C.@SmallSecondaryTextButton #BgBtn2 {
          Text: "";
          FlexWeight: 1;
        }
      }

      // Row 2
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 8);

        $C.@SmallSecondaryTextButton #BgBtn3 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        $C.@SmallSecondaryTextButton #BgBtn4 {
          Text: "";
          FlexWeight: 1;
        }
      }

      // Row 3
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 8);

        $C.@SmallSecondaryTextButton #BgBtn5 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        $C.@SmallSecondaryTextButton #BgBtn6 {
          Text: "";
          FlexWeight: 1;
        }
      }

      // Row 4
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 8);

        $C.@SmallSecondaryTextButton #BgBtn7 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        $C.@SmallSecondaryTextButton #BgBtn8 {
          Text: "";
          FlexWeight: 1;
        }
      }

      // Row 5
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 8);

        $C.@SmallSecondaryTextButton #BgBtn9 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        $C.@SmallSecondaryTextButton #BgBtn10 {
          Text: "";
          FlexWeight: 1;
        }
      }

      // Row 6
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 8);

        $C.@SmallSecondaryTextButton #BgBtn11 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        $C.@SmallSecondaryTextButton #BgBtn12 {
          Text: "";
          FlexWeight: 1;
        }
      }

      // Row 7
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 8);

        $C.@SmallSecondaryTextButton #BgBtn13 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        $C.@SmallSecondaryTextButton #BgBtn14 {
          Text: "";
          FlexWeight: 1;
        }
      }

      // Row 8 (only one button: row trailer is an empty spacer to preserve grid alignment)
      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Top: 8);

        $C.@SmallSecondaryTextButton #BgBtn15 {
          Text: "";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 8); }
        Group { FlexWeight: 1; }
      }
    }

    // -------------------------------------------------------------------
    // Screen 2: detail panel (hidden by default; shown after grid click)
    // -------------------------------------------------------------------
    Group #BgDetailGroup {
      LayoutMode: Top;
      FlexWeight: 1;
      Padding: (Top: 4);
      Visible: false;

      // Background name (large label, centered via flex spacers)
      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Top: 4);

        Label { FlexWeight: 1; }
        Label #BgDetailTitle {
          Text: "";
          Style: (
            TextColor: #ffd700(1),
            FontSize: 20,
            RenderBold: true
          );
        }
        Label { FlexWeight: 1; }
      }

      // Flavor paragraph
      Group {
        LayoutMode: Top;
        Anchor: (Height: 110, Top: 12);
        Padding: (Left: 16, Right: 16);

        Label #BgDetailFlavor {
          Text: "";
          Style: (
            TextColor: #dddddd(1),
            FontSize: 17,
            Wrap: true
          );
        }
      }

      // Stat bonuses (e.g. "+3 STR, +3 CON") — extra Top breathing room
      // separates them from the flavor paragraph above.
      Group {
        LayoutMode: Left;
        Anchor: (Height: 32, Top: 28);

        Label { FlexWeight: 1; }
        Label #BgDetailStats {
          Text: "";
          Style: (
            TextColor: #ffffff(1),
            FontSize: 16,
            RenderBold: true
          );
        }
        Label { FlexWeight: 1; }
      }

      // "Starter Kit" heading
      Group {
        LayoutMode: Left;
        Anchor: (Height: 26, Top: 16);

        Label { FlexWeight: 1; }
        Label #BgDetailKitHeader {
          Text: "Starter Kit";
          Style: (
            TextColor: #ffd700(1),
            FontSize: 15,
            RenderBold: true
          );
        }
        Label { FlexWeight: 1; }
      }

      // Kit lines (up to 3)
      Group {
        LayoutMode: Top;
        Anchor: (Height: 96, Top: 4);
        Padding: (Left: 12, Right: 12);

        Label #BgDetailKitLine1 {
          Text: "";
          Style: (
            TextColor: #ffffff(1),
            FontSize: 14
          );
          Anchor: (Height: 22);
          Visible: false;
        }
        Label #BgDetailKitLine2 {
          Text: "";
          Style: (
            TextColor: #ffffff(1),
            FontSize: 14
          );
          Anchor: (Height: 22, Top: 4);
          Visible: false;
        }
        Label #BgDetailKitLine3 {
          Text: "";
          Style: (
            TextColor: #ffffff(1),
            FontSize: 14
          );
          Anchor: (Height: 22, Top: 4);
          Visible: false;
        }
      }

      // Spacer pushes buttons to the bottom
      Group { FlexWeight: 1; }

      // Confirm / Back row
      Group {
        LayoutMode: Left;
        Anchor: (Height: 52, Top: 8);

        $C.@SmallSecondaryTextButton #BgBackBtn {
          Text: "Back";
          FlexWeight: 1;
        }
        Group { Anchor: (Width: 12); }
        $C.@SmallSecondaryTextButton #BgConfirmBtn {
          Text: "Confirm";
          FlexWeight: 1;
        }
      }
    }
  }
}
