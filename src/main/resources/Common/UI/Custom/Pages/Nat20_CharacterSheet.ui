$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 1100, Height: 780);

  #Content {
    LayoutMode: Top;
    Padding: (Left: 16, Right: 16, Top: 14, Bottom: 14);

    // Header bar: "Name Lvl N" inline on the left, remaining space absorbed
    // by a trailing FlexWeight spacer (labels size to text width).
    Group #CSHeader {
      LayoutMode: Left;
      Anchor: (Height: 40);
      Padding: (Bottom: 6);

      Label #CSName {
        Text: "";
        Style: (TextColor: #ffd700(1), FontSize: 22, RenderBold: true, VerticalAlignment: Center);
      }
      Label #CSLevel {
        Text: "";
        Padding: (Left: 12);
        Style: (TextColor: #ffffff(1), FontSize: 18, RenderBold: true, VerticalAlignment: Center);
      }
      Label { FlexWeight: 1; }
    }

    // Character background placeholder (system WIP). Renders a fixed
    // "Background" string under the header; will become a bound field once
    // authored background data lands.
    Label #CSBackground {
      Text: "Background";
      Anchor: (Height: 18);
      Padding: (Bottom: 8);
      Style: (TextColor: #aaaaaa(1), FontSize: 14, RenderItalics: true);
    }

    // Two-panel body: empty placeholder groups, filled in Tasks 8-19
    Group #CSBody {
      LayoutMode: Left;
      FlexWeight: 1;

      Group #CSLeftPanel {
        LayoutMode: Top;
        FlexWeight: 1;
        Padding: (Right: 12);

        Label #CSLeftHeader {
          Text: "Character Stats";
          Anchor: (Height: 24);
          Padding: (Bottom: 4);
          Style: (TextColor: #cccccc(1), FontSize: 16, RenderBold: true, HorizontalAlignment: Center);
        }

        // XP readout (text)
        Label #CSXpText {
          Anchor: (Height: 18);
          Padding: (Top: 4, Bottom: 2);
          Text: "";
          Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true, HorizontalAlignment: Center);
        }

        // XP bar: dark track + bright fill (width set from Java each rebuild)
        // Track width must match CharacterSheetPage.XP_BAR_TRACK_WIDTH.
        Group #CSXpBarTrack {
          Anchor: (Height: 12, Width: 500);
          Padding: (Top: 2, Bottom: 2);
          Background: (Color: #1c2430(1));

          Group #CSXpBarFill {
            Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 0);
            Background: (Color: #87ceeb(1));
          }
        }

        // Unspent ability points banner. Gold when > 0, muted when = 0.
        // Text + color set from CharacterSheetPage.build().
        Label #CSUnspentBanner {
          Anchor: (Height: 20);
          Padding: (Top: 6, Bottom: 4);
          Text: "";
          Style: (TextColor: #888888(1), FontSize: 13, RenderBold: true, HorizontalAlignment: Center);
        }

        // Six ability rows (Task 11: render only). Plus / minus buttons start
        // disabled; Tasks 12-13 will wire their handlers.
        Group #CSAbilityList {
          LayoutMode: Top;
          Padding: (Top: 4);

          Group #CSAbilityRowSTR {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Padding: (Top: 2, Bottom: 2);

            Label #CSAbilityNameSTR {
              Text: "STR";
              Anchor: (Width: 80);
              Style: (TextColor: #ff4444(1), FontSize: 20, RenderBold: true, VerticalAlignment: Center);
            }
            Label #CSAbilityScoreSTR {
              Text: "";
              FlexWeight: 1;
              Style: (TextColor: #ffffff(1), FontSize: 20, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
            $C.@SmallSecondaryTextButton #CSMinusSTR {
              Text: "-";
              Anchor: (Width: 36, Height: 28);
              Disabled: true;
            }
            $C.@SmallSecondaryTextButton #CSPlusSTR {
              Text: "+";
              Anchor: (Width: 36, Height: 28, Left: 4);
              Disabled: true;
            }
          }

          Group #CSAbilityRowDEX {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Padding: (Top: 2, Bottom: 2);

            Label #CSAbilityNameDEX {
              Text: "DEX";
              Anchor: (Width: 80);
              Style: (TextColor: #44dd66(1), FontSize: 20, RenderBold: true, VerticalAlignment: Center);
            }
            Label #CSAbilityScoreDEX {
              Text: "";
              FlexWeight: 1;
              Style: (TextColor: #ffffff(1), FontSize: 20, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
            $C.@SmallSecondaryTextButton #CSMinusDEX {
              Text: "-";
              Anchor: (Width: 36, Height: 28);
              Disabled: true;
            }
            $C.@SmallSecondaryTextButton #CSPlusDEX {
              Text: "+";
              Anchor: (Width: 36, Height: 28, Left: 4);
              Disabled: true;
            }
          }

          Group #CSAbilityRowCON {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Padding: (Top: 2, Bottom: 2);

            Label #CSAbilityNameCON {
              Text: "CON";
              Anchor: (Width: 80);
              Style: (TextColor: #dd8833(1), FontSize: 20, RenderBold: true, VerticalAlignment: Center);
            }
            Label #CSAbilityScoreCON {
              Text: "";
              FlexWeight: 1;
              Style: (TextColor: #ffffff(1), FontSize: 20, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
            $C.@SmallSecondaryTextButton #CSMinusCON {
              Text: "-";
              Anchor: (Width: 36, Height: 28);
              Disabled: true;
            }
            $C.@SmallSecondaryTextButton #CSPlusCON {
              Text: "+";
              Anchor: (Width: 36, Height: 28, Left: 4);
              Disabled: true;
            }
          }

          Group #CSAbilityRowINT {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Padding: (Top: 2, Bottom: 2);

            Label #CSAbilityNameINT {
              Text: "INT";
              Anchor: (Width: 80);
              Style: (TextColor: #4488ff(1), FontSize: 20, RenderBold: true, VerticalAlignment: Center);
            }
            Label #CSAbilityScoreINT {
              Text: "";
              FlexWeight: 1;
              Style: (TextColor: #ffffff(1), FontSize: 20, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
            $C.@SmallSecondaryTextButton #CSMinusINT {
              Text: "-";
              Anchor: (Width: 36, Height: 28);
              Disabled: true;
            }
            $C.@SmallSecondaryTextButton #CSPlusINT {
              Text: "+";
              Anchor: (Width: 36, Height: 28, Left: 4);
              Disabled: true;
            }
          }

          Group #CSAbilityRowWIS {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Padding: (Top: 2, Bottom: 2);

            Label #CSAbilityNameWIS {
              Text: "WIS";
              Anchor: (Width: 80);
              Style: (TextColor: #ccccdd(1), FontSize: 20, RenderBold: true, VerticalAlignment: Center);
            }
            Label #CSAbilityScoreWIS {
              Text: "";
              FlexWeight: 1;
              Style: (TextColor: #ffffff(1), FontSize: 20, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
            $C.@SmallSecondaryTextButton #CSMinusWIS {
              Text: "-";
              Anchor: (Width: 36, Height: 28);
              Disabled: true;
            }
            $C.@SmallSecondaryTextButton #CSPlusWIS {
              Text: "+";
              Anchor: (Width: 36, Height: 28, Left: 4);
              Disabled: true;
            }
          }

          Group #CSAbilityRowCHA {
            LayoutMode: Left;
            Anchor: (Height: 34);
            Padding: (Top: 2, Bottom: 2);

            Label #CSAbilityNameCHA {
              Text: "CHA";
              Anchor: (Width: 80);
              Style: (TextColor: #bb66ff(1), FontSize: 20, RenderBold: true, VerticalAlignment: Center);
            }
            Label #CSAbilityScoreCHA {
              Text: "";
              FlexWeight: 1;
              Style: (TextColor: #ffffff(1), FontSize: 20, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
            $C.@SmallSecondaryTextButton #CSMinusCHA {
              Text: "-";
              Anchor: (Width: 36, Height: 28);
              Disabled: true;
            }
            $C.@SmallSecondaryTextButton #CSPlusCHA {
              Text: "+";
              Anchor: (Width: 36, Height: 28, Left: 4);
              Disabled: true;
            }
          }
        }

        // Apply queued ability point spend. Enabled only when pendingDelta > 0
        // somewhere. Task 14 wires the OnClick handler.
        $C.@SmallSecondaryTextButton #CSApplyBtn {
          Text: "Apply";
          Anchor: (Height: 28, Width: 120, Top: 10);
          Disabled: true;
        }

        // =========================================================
        // Party section: Party / Server / Invites tabs + scrolling
        // rows shared across tabs. Button visibility + text is set
        // per tab from CharacterSheetPage.renderPartySection().
        // Design reference:
        //   docs/plans/2026-04-21-party-multiplayer-quest-design.md
        // =========================================================
        Group #CSPartySection {
          LayoutMode: Top;
          Padding: (Top: 16);
          FlexWeight: 1;

          Label #CSPartyHeader {
            Text: "Party";
            Anchor: (Height: 24);
            Padding: (Bottom: 4);
            Style: (TextColor: #cccccc(1), FontSize: 16, RenderBold: true, HorizontalAlignment: Center);
          }

          Group #CSPartyTabBar {
            LayoutMode: Left;
            Anchor: (Height: 28);
            Padding: (Bottom: 4);

            Label { FlexWeight: 1; }
            $C.@SmallSecondaryTextButton #CSPartyTabParty {
              Text: "Party";
              Anchor: (Width: 90, Height: 24);
            }
            $C.@SmallSecondaryTextButton #CSPartyTabInvites {
              Text: "Invites";
              Anchor: (Width: 90, Height: 24, Left: 4);
            }
            $C.@SmallSecondaryTextButton #CSPartyTabServer {
              Text: "Server";
              Anchor: (Width: 90, Height: 24, Left: 4);
            }
            Label { FlexWeight: 1; }
          }

          Label #CSPartyEmptyState {
            Anchor: (Height: 18);
            Text: "";
            Visible: false;
            Style: (TextColor: #888888(1), FontSize: 12, HorizontalAlignment: Center);
          }

          // 8 pre-baked rows. Each row has a name label and two buttons
          // (A / B). Rendering by tab:
          //   Party   : A=Kick   B=Promote  (leader-only, non-self)
          //   Server  : A=Invite B=hidden
          //   Invites : A=Accept B=Decline
          Group #CSPartyList {
            LayoutMode: TopScrolling;
            FlexWeight: 1;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;

            Group #CSPartyRow0 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName0 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA0 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB0 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
            Group #CSPartyRow1 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName1 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA1 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB1 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
            Group #CSPartyRow2 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName2 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA2 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB2 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
            Group #CSPartyRow3 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName3 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA3 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB3 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
            Group #CSPartyRow4 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName4 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA4 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB4 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
            Group #CSPartyRow5 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName5 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA5 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB5 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
            Group #CSPartyRow6 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName6 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA6 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB6 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
            Group #CSPartyRow7 {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Padding: (Top: 2, Bottom: 2);
              Visible: false;

              Label #CSPartyRowName7 {
                FlexWeight: 1;
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, VerticalAlignment: Center);
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnA7 {
                Text: "";
                Anchor: (Width: 110, Height: 24, Left: 4);
                Visible: false;
              }
              $C.@SmallSecondaryTextButton #CSPartyRowBtnB7 {
                Text: "";
                Anchor: (Width: 90, Height: 24, Left: 4);
                Visible: false;
              }
            }
          }

          // Leave Party + Cancel buttons, shown only on the Party tab.
          // First click on Leave swaps its label to "Confirm Leave" and
          // reveals #CSPartyLeaveCancelBtn; a second click on Leave commits
          // the leave, while Cancel aborts the pending confirm.
          Group #CSPartyLeaveRow {
            LayoutMode: Left;
            Anchor: (Height: 28, Top: 6);
            Visible: false;

            $C.@SmallSecondaryTextButton #CSPartyLeaveBtn {
              Text: "Leave Party";
              Anchor: (Width: 140, Height: 28);
            }
            $C.@SmallSecondaryTextButton #CSPartyLeaveCancelBtn {
              Text: "Cancel";
              Anchor: (Width: 90, Height: 28, Left: 6);
              Visible: false;
            }
          }
        }
      }

      // Vertical divider between the two panels.
      Group {
        Anchor: (Width: 1);
        Background: (Color: #3a4a5a(1));
      }

      Group #CSRightPanel {
        LayoutMode: Top;
        FlexWeight: 1;
        Padding: (Left: 12);

        Label #CSRightHeader {
          Text: "Quest Log";
          Anchor: (Height: 24);
          Padding: (Bottom: 4);
          Style: (TextColor: #cccccc(1), FontSize: 16, RenderBold: true, HorizontalAlignment: Center);
        }

        // Active / Completed tab buttons. Click toggles list mode. Task 16.
        // Tab text color is recolored from Java each rebuild: gold for the
        // active tab, muted grey for the inactive tab.
        Group #CSTabBar {
          LayoutMode: Left;
          Anchor: (Height: 28);
          Padding: (Bottom: 4);

          Label { FlexWeight: 1; }
          $C.@SmallSecondaryTextButton #CSTabActive {
            Text: "Active";
            Anchor: (Width: 80, Height: 24);
          }
          $C.@SmallSecondaryTextButton #CSTabCompleted {
            Text: "Completed";
            Anchor: (Width: 140, Height: 24, Left: 4);
          }
          Label { FlexWeight: 1; }
        }

        // Empty-state hint shown when the current tab has zero quests. Task 16.
        Label #CSEmptyState {
          Anchor: (Height: 18);
          Text: "";
          Visible: false;
          Style: (TextColor: #888888(1), FontSize: 12, HorizontalAlignment: Center);
        }

        // Quest rows: 20 pre-baked slots, all hidden by default. The Java
        // renderer toggles Visible + sets Name / Objective text per slot.
        // Pin indicators are deferred to Task 18 (which also wires row tap
        // handlers + the waypoint toggle visuals). Task 17.
        Group #CSQuestList {
          LayoutMode: TopScrolling;
          FlexWeight: 1;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Group #CSQuestRow0 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName0 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj0 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle0 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow1 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName1 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj1 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle1 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow2 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName2 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj2 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle2 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow3 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName3 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj3 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle3 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow4 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName4 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj4 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle4 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow5 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName5 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj5 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle5 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow6 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName6 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj6 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle6 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow7 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName7 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj7 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle7 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow8 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Label #CSQuestName8 {
                Anchor: (Height: 16);
                Text: "";
                Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
              }
              Label #CSQuestObj8 {
                Anchor: (Height: 14);
                Text: "";
                Padding: (Top: 2);
                Style: (TextColor: #cccccc(1), FontSize: 11);
              }
            }

            $C.@SmallSecondaryTextButton #CSQuestToggle8 {
              Text: "";
              Anchor: (Width: 110, Height: 28, Left: 4);
              Visible: false;
            }
          }
          Group #CSQuestRow9 {
            LayoutMode: Left;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;

            Group {
              FlexWeight: 1;
