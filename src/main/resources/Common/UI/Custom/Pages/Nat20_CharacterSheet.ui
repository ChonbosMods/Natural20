        Group #CSQuestList {
          LayoutMode: TopScrolling;
          FlexWeight: 1;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Button #CSQuestRow0 {
            LayoutMode: Top;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;
            Label #CSQuestName0 {
              Anchor: (Height: 16);
              Text: "";
              Style: (TextColor: #ffffff(1), FontSize: 13, RenderBold: true);
            }
            Label #CSQuestObj0 {
              Anchor: (Height: 14);
              Text: "";
              Padding: (Top: 2);
              Style: (TextColor: #cccccc(1), FontSize: 11);
            }
          }
          Button #CSQuestRow1 {
            LayoutMode: Top;
            Anchor: (Height: 44);
            Padding: (Top: 3, Bottom: 3);
            Visible: false;
            Label #CSQuestName1 {
              Anchor: (Height: 16);
